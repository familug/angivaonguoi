# Copy to .env.prod and fill in real values before deploying

# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=replace_with_64_char_secret

# Public hostname (no https://)
PHX_HOST=angi.pymi.vn

# Gemini Vision API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Secret invite code required to register new accounts
REFER_CODE=your_secret_invite_code

# PostgreSQL password (choose a strong password)
POSTGRES_PASSWORD=change_me_strong_password
